# ── Supabase ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — usada só em rotas server-only (/api/track, webhooks,
# crons). Ignora RLS. NUNCA expor com prefixo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Segredos por oferta (criptografia) ────────────────────────────────
# Chave usada para criptografar (AES-256-GCM) os tokens colados no
# formulário de cada oferta — Token CAPI, Token da Marketing API e GA4 API
# secret ficam salvos no banco já criptografados com essa chave; sem ela,
# o sistema não consegue nem salvar nem ler nenhum token.
#
# Gere uma vez (ex.: `openssl rand -base64 32`) e nunca troque depois de
# ter tokens salvos — trocar a chave torna os tokens já salvos ilegíveis
# (peça pra recadastrar as ofertas se isso acontecer).
SECRETS_ENCRYPTION_KEY=

# ── Hotmart ─────────────────────────────────────────────────────────────
# Token enviado no header "hottok" pela Hotmart, validado em
# /api/webhooks/hotmart. Enquanto não definida, a validação é pulada
# (útil em desenvolvimento) — defina antes de ir para produção.
HOTMART_HOTTOK=
#
# Credenciais da API de Vendas da Hotmart (Ferramentas → Manager →
# Credenciais no painel dela) — usadas só no backfill manual de vendas
# retroativas ("Vendas retroativas" em Configurações → Ofertas). Globais,
# não por oferta (a Hotmart gera um Client ID/Secret por conta, não por
# produto).
HOTMART_CLIENT_ID=
HOTMART_CLIENT_SECRET=

# ── Meta (Conversions API + Marketing API) ────────────────────────────
# Pixel ID, Token CAPI e Token da Marketing API ficam configurados por
# oferta em Configurações → Ofertas (os tokens são colados direto no
# formulário e salvos criptografados — não precisam de env var aqui).
#
# test_event_code para validar no Gerenciador de Eventos da Meta durante o
# desenvolvimento (opcional, por oferta). Nome derivado automaticamente do
# slug da oferta: META_TEST_EVENT_CODE_<SLUG-EM-MAIÚSCULO-COM-UNDERSCORE>.
# Para a oferta de slug "oferta-1":
# META_TEST_EVENT_CODE_OFERTA_1=
#
# Fallback legado (opcional): se uma oferta não tiver token da Marketing
# API próprio cadastrado, o cron usa este token global.
META_MARKETING_API_ACCESS_TOKEN=
#
# Protege /api/cron/meta-spend. A Vercel injeta
# "Authorization: Bearer <CRON_SECRET>" automaticamente nas chamadas do
# Cron quando essa env var está definida no projeto.
CRON_SECRET=

# ── GA4 (Measurement Protocol) ─────────────────────────────────────────
# Measurement ID e API secret ficam configurados por oferta em
# Configurações → Ofertas (o secret é colado direto no formulário e salvo
# criptografado — não precisa de env var aqui).

# ── App ─────────────────────────────────────────────────────────────────
# URL pública do painel/track.js em produção (usada em CORS e nos snippets
# de instalação gerados na tela de Configurações).
NEXT_PUBLIC_APP_URL=http://localhost:3000
